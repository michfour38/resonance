model witness_feedback {
  id String @id @default(cuid())

  cycle_id       String @db.Uuid
  participant_id String @db.Uuid

  latest_answer String  @db.Text
  witness_reply String? @db.Text

  strongest_anchor String?
  strongest_signal String?

  feedback String @db.Text

  created_at DateTime @default(now())

  cycle harmonize_cycles @relation(fields: [cycle_id], references: [id], onDelete: Cascade)

  @@index([cycle_id])
  @@index([participant_id])
}