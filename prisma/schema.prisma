generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model circle_members {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  circle_id String     @db.Uuid
  user_id   String
  role      CircleRole @default(member)
  joined_at DateTime   @default(now()) @db.Timestamptz(6)
  circles   circles    @relation(fields: [circle_id], references: [id])
  profiles  profiles   @relation(fields: [user_id], references: [id])

  @@unique([circle_id, user_id])
  @@index([circle_id])
  @@index([user_id])
}

model compass_sessions {
  id      String @id @default(cuid())
  user_id String
  status  String @default("active")

  phase         String?
  selected_area String?

  area_responses      Json?
  recursive_layers    Json?
  possibility_answers Json?
  resistance_map      Json?
  discussion_messages Json?

  proposed_step String?
  final_step    String?

  detected_patterns Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([status])
}

model prompt_analyses {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  completion_id      String             @db.Uuid
  author_id          String
  content            String
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @updatedAt @db.Timestamptz(6)
  status             AnalysisStatus     @default(private)
  profiles           profiles           @relation(fields: [author_id], references: [id])
  prompt_completions prompt_completions @relation(fields: [completion_id], references: [id])

  @@unique([completion_id, author_id])
  @@index([completion_id])
  @@index([author_id])
}

model prompt_reactions {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  completion_id      String             @db.Uuid
  user_id            String
  type               ReactionType
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  prompt_completions prompt_completions @relation(fields: [completion_id], references: [id])
  profiles           profiles           @relation(fields: [user_id], references: [id])

  @@unique([completion_id, user_id, type])
  @@index([completion_id])
  @@index([user_id])
}

model mirror_feedback {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  week_number Int
  day_number  Int
  feedback    String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)
  note        String?

  @@unique([user_id, week_number, day_number])
  @@index([user_id])
}

model circle_posts {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  circle_id          String           @db.Uuid
  user_id            String
  room_id            String?          @db.Uuid
  prompt_id          String?          @db.Uuid
  parent_id          String?          @db.Uuid
  content            String
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @db.Timestamptz(6)
  deleted_at         DateTime?        @db.Timestamptz(6)
  categories         String[]         @default([])
  risk_score         Int              @default(0)
  severity           String?
  circles            circles          @relation(fields: [circle_id], references: [id])
  circle_posts       circle_posts?    @relation("circle_postsTocircle_posts", fields: [parent_id], references: [id])
  other_circle_posts circle_posts[]   @relation("circle_postsTocircle_posts")
  circle_prompts     circle_prompts?  @relation(fields: [prompt_id], references: [id])
  rooms              rooms?           @relation(fields: [room_id], references: [id])
  profiles           profiles         @relation(fields: [user_id], references: [id])
  post_witnesses     post_witnesses[]
  reports            reports[]

  @@index([circle_id, created_at])
}

model post_witnesses {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id      String       @db.Uuid
  user_id      String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  circle_posts circle_posts @relation(fields: [post_id], references: [id])
  profiles     profiles     @relation(fields: [user_id], references: [id])

  @@unique([post_id, user_id])
  @@index([post_id])
  @@index([user_id])
}

model circle_prompts {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  circle_id    String         @db.Uuid
  room_id      String?        @db.Uuid
  author_id    String
  content      String
  is_intro     Boolean        @default(false)
  is_pinned    Boolean        @default(false)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  circle_posts circle_posts[]
  profiles     profiles       @relation(fields: [author_id], references: [id])
  circles      circles        @relation(fields: [circle_id], references: [id])
  rooms        rooms?         @relation(fields: [room_id], references: [id])

  @@index([circle_id])
}

model circles {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohort_id      String           @db.Uuid
  name           String
  facilitator_id String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  circle_members circle_members[]
  circle_posts   circle_posts[]
  circle_prompts circle_prompts[]
  cohorts        cohorts          @relation(fields: [cohort_id], references: [id])
  profiles       profiles?        @relation(fields: [facilitator_id], references: [id])

  @@index([cohort_id])
}

model cohort_members {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohort_id    String       @db.Uuid
  user_id      String
  status       MemberStatus @default(enrolled)
  enrolled_at  DateTime     @default(now()) @db.Timestamptz(6)
  activated_at DateTime?    @db.Timestamptz(6)
  withdrawn_at DateTime?    @db.Timestamptz(6)
  cohorts      cohorts      @relation(fields: [cohort_id], references: [id])
  profiles     profiles     @relation(fields: [user_id], references: [id])

  @@unique([cohort_id, user_id])
  @@index([cohort_id])
  @@index([user_id])
}

model cohorts {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  pathway          Pathway?
  start_at         DateTime           @db.Timestamptz(6)
  status           CohortStatus       @default(draft)
  max_members      Int?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @db.Timestamptz(6)
  timezone         String             @default("Africa/Johannesburg")
  circles          circles[]
  cohort_members   cohort_members[]
  journey_progress journey_progress[]
}

model resonance_day_continues {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String
  week_number  Int
  day_number   Int
  continued_at DateTime @default(now()) @db.Timestamptz(6)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, week_number, day_number])
  @@index([user_id])
  @@index([week_number, day_number])
  @@map("journey_day_continues")
}

model inquiry_sessions {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reflection_session_id String              @unique @db.Uuid
  current_layer         Int                 @default(1)
  completed             Boolean             @default(false)
  abandoned             Boolean             @default(false)
  layer_responses       Json                @default("{}")
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  updated_at            DateTime            @db.Timestamptz(6)
  reflection_sessions   reflection_sessions @relation(fields: [reflection_session_id], references: [id])
}

model insight_definitions {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String          @unique
  name            String
  description     String
  unlock_criteria Json
  user_insights   user_insights[]
}

model journal_entries {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  room_id     String?    @db.Uuid
  entry_phase EntryPhase @default(in_journey)
  content     String
  word_count  Int        @default(0)
  is_private  Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @db.Timestamptz(6)
  rooms       rooms?     @relation(fields: [room_id], references: [id])
  profiles    profiles   @relation(fields: [user_id], references: [id])

  @@index([user_id, entry_phase])
}

model resonance_weeks {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id        String           @unique @db.Uuid
  week_number    Int              @unique
  title          String
  theme          String
  is_published   Boolean          @default(false)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  resonance_days resonance_days[]
  rooms          rooms            @relation(fields: [room_id], references: [id])

  @@index([week_number])
  @@map("journey_weeks")
}

model resonance_days {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  week_id         String          @db.Uuid
  day_number      Int
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  day_prompts     day_prompts[]
  resonance_weeks resonance_weeks @relation(fields: [week_id], references: [id])

  @@unique([week_id, day_number])
  @@index([week_id])
  @@map("journey_days")
}

model day_prompts {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  day_id             String               @db.Uuid
  type               PromptType
  prompt_order       Int
  label              String?
  content            String
  is_published       Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  resonance_days     resonance_days       @relation(fields: [day_id], references: [id])
  prompt_completions prompt_completions[]

  @@index([day_id, prompt_order])
}

model prompt_completions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prompt_id        String             @db.Uuid
  user_id          String
  response         String
  is_shared        Boolean            @default(false)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @updatedAt @db.Timestamptz(6)
  prompt_analyses  prompt_analyses[]
  day_prompts      day_prompts        @relation(fields: [prompt_id], references: [id])
  profiles         profiles           @relation(fields: [user_id], references: [id])
  prompt_reactions prompt_reactions[]

  @@unique([prompt_id, user_id])
  @@index([prompt_id])
  @@index([user_id])
}

model journey_progress {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String
  cohort_id           String         @db.Uuid
  room_id             String         @db.Uuid
  status              ProgressStatus @default(locked)
  scheduled_unlock_at DateTime       @db.Timestamptz(6)
  unlocked_at         DateTime?      @db.Timestamptz(6)
  completed_at        DateTime?      @db.Timestamptz(6)
  admin_override      Boolean        @default(false)
  cohorts             cohorts        @relation(fields: [cohort_id], references: [id])
  rooms               rooms          @relation(fields: [room_id], references: [id])
  profiles            profiles       @relation(fields: [user_id], references: [id])

  @@unique([user_id, cohort_id, room_id])
  @@index([cohort_id])
  @@index([scheduled_unlock_at])
  @@index([user_id])
}

model notifications {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  type       String
  payload    Json     @default("{}")
  read       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  profiles   profiles @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model mirror_responses {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String
  week_number       Int
  day_number        Int
  input_snapshot    Json
  output            String
  patterns_detected String[]
  contradictions    String[]
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  tier              String   @default("lite")
  profiles          profiles @relation(fields: [user_id], references: [id])

  @@unique([user_id, week_number, day_number])
  @@index([user_id])
  @@index([user_id, week_number, day_number])
}

model profiles {
  id                                         String                   @id
  display_name                               String
  pathway                                    Pathway
  worldview_tags                             String[]                 @default([])
  value_themes                               String[]                 @default([])
  journey_status                             JourneyStatus            @default(waiting)
  onboarding_done                            Boolean                  @default(false)
  is_admin                                   Boolean                  @default(false)
  invited_by                                 String?
  timezone                                   String?
  created_at                                 DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                                 DateTime                 @db.Timestamptz(6)
  circle_members                             circle_members[]
  circle_posts                               circle_posts[]
  circle_prompts                             circle_prompts[]
  circles                                    circles[]
  cohort_members                             cohort_members[]
  journal_entries                            journal_entries[]
  journey_progress                           journey_progress[]
  mirror_responses                           mirror_responses[]
  notifications                              notifications[]
  post_witnesses                             post_witnesses[]
  profiles                                   profiles?                @relation("profilesToprofiles", fields: [invited_by], references: [id])
  other_profiles                             profiles[]               @relation("profilesToprofiles")
  prompt_analyses                            prompt_analyses[]
  prompt_completions                         prompt_completions[]
  prompt_reactions                           prompt_reactions[]
  reflection_sessions                        reflection_sessions[]
  reports_reports_reported_user_idToprofiles reports[]                @relation("reports_reported_user_idToprofiles")
  reports_reports_reporter_idToprofiles      reports[]                @relation("reports_reporter_idToprofiles")
  reports_reports_reviewed_byToprofiles      reports[]                @relation("reports_reviewed_byToprofiles")
  user_insights                              user_insights[]
  harmonize_systems                          harmonize_systems[]
  harmonize_participants                     harmonize_participants[]
}

model reflection_messages {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id          String              @db.Uuid
  role                MessageRole
  content             String
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  reflection_sessions reflection_sessions @relation(fields: [session_id], references: [id])

  @@index([session_id, created_at])
}

model reflection_sessions {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String
  room_id             String                @db.Uuid
  session_type        SessionType
  status              SessionStatus         @default(active)
  summary             String?
  started_at          DateTime              @default(now()) @db.Timestamptz(6)
  ended_at            DateTime?             @db.Timestamptz(6)
  inquiry_sessions    inquiry_sessions?
  reflection_messages reflection_messages[]
  rooms               rooms                 @relation(fields: [room_id], references: [id])
  profiles            profiles              @relation(fields: [user_id], references: [id])

  @@index([user_id, room_id])
}

model reports {
  id                                          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id                                 String
  reported_user_id                            String?
  reported_post_id                            String?       @db.Uuid
  reason                                      String
  status                                      ReportStatus  @default(pending)
  admin_notes                                 String?
  created_at                                  DateTime      @default(now()) @db.Timestamptz(6)
  reviewed_at                                 DateTime?     @db.Timestamptz(6)
  reviewed_by                                 String?
  circle_posts                                circle_posts? @relation(fields: [reported_post_id], references: [id])
  profiles_reports_reported_user_idToprofiles profiles?     @relation("reports_reported_user_idToprofiles", fields: [reported_user_id], references: [id])
  profiles_reports_reporter_idToprofiles      profiles      @relation("reports_reporter_idToprofiles", fields: [reporter_id], references: [id])
  profiles_reports_reviewed_byToprofiles      profiles?     @relation("reports_reviewed_byToprofiles", fields: [reviewed_by], references: [id])

  @@index([reported_post_id])
  @@index([status])
}

model rooms {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String                @unique
  name                String
  week_number         Int
  theme               String
  is_integration      Boolean               @default(false)
  circle_posts        circle_posts[]
  circle_prompts      circle_prompts[]
  journal_entries     journal_entries[]
  journey_progress    journey_progress[]
  resonance_weeks     resonance_weeks?
  reflection_sessions reflection_sessions[]
}

model user_insights {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String
  insight_id          String              @db.Uuid
  status              InsightStatus       @default(locked)
  content             Json?
  unlocked_at         DateTime?           @db.Timestamptz(6)
  insight_definitions insight_definitions @relation(fields: [insight_id], references: [id])
  profiles            profiles            @relation(fields: [user_id], references: [id])

  @@unique([user_id, insight_id])
}

model mirror_unlocks {
  id          String    @id @default(uuid())
  user_id     String
  week_number Int
  day_number  Int
  tier        String
  is_paid     Boolean   @default(false)
  unlocked_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@unique([user_id, week_number, day_number, tier])
}

model entry_leads {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                  @unique
  first_name              String?
  source                  String?
  pathway                 Pathway?
  intro_started_at        DateTime?               @db.Timestamptz(6)
  last_seen_panel         Int?
  last_seen_panel_key     String?
  last_seen_panel_at      DateTime?               @db.Timestamptz(6)
  intro_completed_at      DateTime?               @db.Timestamptz(6)
  entered_journey_at      DateTime?               @db.Timestamptz(6)
  created_at              DateTime                @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                @updatedAt @db.Timestamptz(6)
  entry_paid_at           DateTime?               @db.Timestamptz(6)
  entry_access_expires_at DateTime?               @db.Timestamptz(6)
  journey_paid_at         DateTime?               @db.Timestamptz(6)
  journey_access_granted  Boolean                 @default(false)
  entry_mirror_sessions   entry_mirror_sessions[]

  @@index([email])
  @@index([source])
  @@index([pathway])
  @@index([last_seen_panel])
}

model entry_mirror_sessions {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String    @db.Uuid
  entry_type          String
  status              String    @default("active")
  started_at          DateTime  @default(now()) @db.Timestamptz(6)
  completed_at        DateTime? @db.Timestamptz(6)
  mirror_generated_at DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @updatedAt @db.Timestamptz(6)

  entry_leads entry_leads @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  entry_mirror_responses entry_mirror_responses[]
  entry_mirror_outputs   entry_mirror_outputs[]

  @@index([lead_id])
  @@index([entry_type])
  @@index([status])
}

model entry_mirror_responses {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String   @db.Uuid
  question_key   String
  question_text  String
  response       String
  response_order Int
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  entry_mirror_sessions entry_mirror_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, question_key])
  @@index([session_id])
  @@index([response_order])
}

model entry_mirror_outputs {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id        String   @db.Uuid
  output            String
  questions         String[] @default([])
  themes_detected   String[] @default([])
  tensions_detected String[] @default([])
  input_snapshot    Json     @default("{}")
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  entry_mirror_sessions entry_mirror_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
}

model harmonize_systems {
  owner_profile_id String?
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode             HarmonizeMode
  name             String?
  status           HarmonizeSystemStatus @default(active)
  consent_snapshot Json                  @default("{}")
  created_by       String

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  profiles     profiles                 @relation(fields: [created_by], references: [id])
  participants harmonize_participants[]
  cycles       harmonize_cycles[]
  invites      harmonize_invites[]

  @@index([mode])
  @@index([status])
  @@index([created_by])
}

model harmonize_invites {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  system_id            String  @db.Uuid
  email                String
  relationship_context String?

  status String @default("pending")

  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  accepted_at DateTime? @db.Timestamptz(6)

  systems harmonize_systems @relation(fields: [system_id], references: [id], onDelete: Cascade)

  @@index([system_id])
  @@index([email])
  @@index([status])
}

model harmonize_participants {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  system_id  String @db.Uuid
  profile_id String

  role                 HarmonizeRole
  relationship_context String?
  is_minor             Boolean       @default(false)

  birthdate            DateTime? @db.Date
  minor_access_enabled Boolean   @default(false)
  guardian_verified    Boolean   @default(false)

  active Boolean @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  systems  harmonize_systems @relation(fields: [system_id], references: [id], onDelete: Cascade)
  profiles profiles          @relation(fields: [profile_id], references: [id])

  entries      harmonize_entries[]
  cycle_labels harmonize_cycle_labels[]

  @@unique([system_id, profile_id])
  @@index([system_id])
  @@index([profile_id])
  @@index([role])
}

model harmonize_cycles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  system_id        String             @db.Uuid
  witness_feedback witness_feedback[]

  title  String?
  status HarmonizeCycleStatus @default(active)

  signal_snapshot  Json @default("{}")
  pattern_snapshot Json @default("{}")
  system_snapshot  Json @default("{}")

  started_at  DateTime  @default(now()) @db.Timestamptz(6)
  reviewed_at DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @updatedAt @db.Timestamptz(6)

  systems            harmonize_systems           @relation(fields: [system_id], references: [id], onDelete: Cascade)
  entries            harmonize_entries[]
  reviews            harmonize_reviews[]
  witness_anchors    harmonize_witness_anchors[]
  participant_labels harmonize_cycle_labels[]

  @@index([system_id])
  @@index([status])
}

model harmonize_cycle_labels {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  cycle_id       String @db.Uuid
  participant_id String @db.Uuid

  label String

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  cycles       harmonize_cycles       @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  participants harmonize_participants @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@unique([cycle_id, participant_id])
  @@index([cycle_id])
  @@index([participant_id])
}

model harmonize_entries {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycle_id       String @db.Uuid
  participant_id String @db.Uuid

  scope   HarmonizeScope
  content String

  question_key String?
  prompt_text  String?
  phase        String?

  share_risk_level            Int     @default(0)
  requires_review_before_send Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  cycles          harmonize_cycles            @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  participants    harmonize_participants      @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  share_reviews   harmonize_share_reviews[]
  witness_anchors harmonize_witness_anchors[]

  @@index([cycle_id])
  @@index([participant_id])
  @@index([scope])
}

model harmonize_witness_anchors {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  cycle_id String  @db.Uuid
  entry_id String? @db.Uuid

  anchor_type String
  anchor_name String

  confidence Float @default(0)

  behavioral_markers Json @default("[]")
  evidence           Json @default("[]")

  strength Float @default(0)

  source String @default("entry")

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  cycles  harmonize_cycles   @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  entries harmonize_entries? @relation(fields: [entry_id], references: [id], onDelete: SetNull)

  outgoing_relationships harmonize_anchor_relationships[] @relation("AnchorSource")
  incoming_relationships harmonize_anchor_relationships[] @relation("AnchorTarget")

  @@index([cycle_id])
  @@index([entry_id])
  @@index([anchor_type])
  @@index([source])
  @@index([strength])
}

model harmonize_anchor_relationships {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  source_anchor_id String @db.Uuid
  target_anchor_id String @db.Uuid

  relationship_type String
  reason            String?

  created_at DateTime @default(now()) @db.Timestamptz(6)

  source_anchor harmonize_witness_anchors @relation("AnchorSource", fields: [source_anchor_id], references: [id], onDelete: Cascade)
  target_anchor harmonize_witness_anchors @relation("AnchorTarget", fields: [target_anchor_id], references: [id], onDelete: Cascade)

  @@index([source_anchor_id])
  @@index([target_anchor_id])
  @@index([relationship_type])
}

model harmonize_share_reviews {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entry_id String @db.Uuid

  risk_level Int    @default(0)
  risk_type  String
  reason     String

  approved    Boolean   @default(false)
  reviewed_at DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)

  entries harmonize_entries @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@index([entry_id])
  @@index([risk_type])
}

model harmonize_reviews {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycle_id String @db.Uuid

  outcome HarmonizeOutcome
  summary String?

  same_within_self      String?
  different_within_self String?
  different_in_system   String?
  newly_visible         String?
  five_percent_practice String?

  created_at DateTime @default(now()) @db.Timestamptz(6)

  cycles harmonize_cycles @relation(fields: [cycle_id], references: [id], onDelete: Cascade)

  @@index([cycle_id])
  @@index([outcome])
}

