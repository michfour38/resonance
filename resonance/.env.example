# .env.example
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Found in: https://dashboard.clerk.com → your app → API Keys
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is safe to expose to the browser.
# CLERK_SECRET_KEY is server-side only — never use in client code.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# Clerk redirect URLs — where to send users after sign-in / sign-up / sign-out
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/welcome

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Found in: Railway dashboard → your PostgreSQL service → Connect tab
#
# For Railway: set both DATABASE_URL and DIRECT_URL to the same connection string.
# Do NOT add ?pgbouncer=true — Railway does not use pgBouncer.
#
# For Supabase DB (if used instead of Railway):
#   DATABASE_URL  = pooled connection string (with ?pgbouncer=true)
#   DIRECT_URL    = direct connection string  (without pgbouncer)

DATABASE_URL=postgresql://postgres:password@host:port/dbname
DIRECT_URL=postgresql://postgres:password@host:port/dbname

# ── Anthropic (AI Reflection) ──────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
# Used by the AI streaming endpoint (Sprint 3). Can be left blank for now.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Resend (Email Notifications) ──────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used by the notification service (Sprint 8). Can be left blank for now.
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=hello@yourdomain.com

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
